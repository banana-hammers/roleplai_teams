  "Next.js API Route (App Router)": {
    "prefix": "napi",
    "body": [
      "import { NextRequest, NextResponse } from 'next/server'",
      "",
      "export async function ${1|GET,POST,PUT,DELETE,PATCH|}(request: NextRequest) {",
      "  try {",
      "    ${2:// Implementation}",
      "    ",
      "    return NextResponse.json({ ${3:data} })",
      "  } catch (error) {",
      "    console.error('${4:Error}:', error)",
      "    return NextResponse.json(",
      "      { error: '${5:Error message}' },",
      "      { status: 500 }",
      "    )",
      "  }",
      "}"
    ],
    "description": "Next.js API Route (App Router)"
  },
  "Next.js API Route with Edge Runtime": {
    "prefix": "napiedge",
    "body": [
      "import { NextRequest, NextResponse } from 'next/server'",
      "",
      "export const runtime = 'edge'",
      "",
      "export async function ${1|GET,POST,PUT,DELETE,PATCH|}(request: NextRequest) {",
      "  try {",
      "    ${2:// Implementation}",
      "    ",
      "    return NextResponse.json({ ${3:data} })",
      "  } catch (error) {",
      "    return NextResponse.json(",
      "      { error: '${4:Error message}' },",
      "      { status: 500 }",
      "    )",
      "  }",
      "}"
    ],
    "description": "Next.js API Route with Edge Runtime"
  },
