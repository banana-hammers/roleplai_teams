  "Supabase Query with RLS": {
    "prefix": "supaquery",
    "body": [
      "const { data, error } = await supabase",
      "  .from('${1:table}')",
      "  .select('${2:*}')",
      "  ${3:// .eq('column', value)}",
      "",
      "if (error) {",
      "  console.error('Error fetching ${1:table}:', error)",
      "  throw error",
      "}",
      "",
      "${4:// Use data}"
    ],
    "description": "Supabase query with error handling"
  },
  "Vercel AI SDK useChat": {
    "prefix": "usechat",
    "body": [
      "import { useChat } from 'ai/react'",
      "",
      "const { messages, input, handleInputChange, handleSubmit, isLoading } = useChat({",
      "  api: '${1:/api/chat}',",
      "  ${2:// Additional options}",
      "})",
      "${3}"
    ],
    "description": "Vercel AI SDK useChat hook"
  },
  "AI Chat API Route": {
    "prefix": "aichat",
    "body": [
      "import { createClient } from '@/lib/supabase/server'",
      "import { openai } from '@ai-sdk/openai'",
      "import { anthropic } from '@ai-sdk/anthropic'",
      "import { streamText } from 'ai'",
      "",
      "export const runtime = 'edge'",
      "",
      "export async function POST(req: Request) {",
      "  const { messages, provider = 'openai', model } = await req.json()",
      "  const supabase = await createClient()",
      "",
      "  const { data: { user } } = await supabase.auth.getUser()",
      "  if (!user) {",
      "    return new Response('Unauthorized', { status: 401 })",
      "  }",
      "",
      "  const result = streamText({",
      "    model: provider === 'anthropic' ",
      "      ? anthropic(model || 'claude-3-5-sonnet-20241022')",
      "      : openai(model || 'gpt-4-turbo-preview'),",
      "    messages,",
      "  })",
      "",
      "  return result.toDataStreamResponse()",
      "}"
    ],
    "description": "AI Chat API route with streaming"
  },
  "TypeScript Interface": {
    "prefix": "tsinterface",
    "body": [
      "interface ${1:Name} {",
      "  ${2:property}: ${3:type}",
      "}"
    ],
    "description": "TypeScript interface"
  },
  "React Hook": {
    "prefix": "rh",
    "body": [
      "import { ${1|useState,useEffect,useCallback,useMemo|} } from 'react'",
      "",
      "export function use${2:HookName}() {",
      "  ${3:// Implementation}",
      "  ",
      "  return ${4:value}",
      "}"
    ],
    "description": "Custom React hook"
  }
}
